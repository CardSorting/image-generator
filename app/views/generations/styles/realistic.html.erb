<div class="max-w-2xl mx-auto py-8">
  <h1 class="text-3xl font-bold text-gray-900 mb-4">Realistic Style Generation</h1>
  
  <p class="mb-8 text-gray-600">
    Create highly detailed, photorealistic images with precise textures and lighting. Perfect for 
    professional photography-like results, architectural visualizations, and true-to-life representations.
  </p>

  <%= render "form", 
    prompt_placeholder: "Example: A detailed close-up of a dewdrop on a red rose petal, with morning sunlight creating rainbow refractions...", 
    prompt_help: "Include specific details about textures, materials, lighting conditions, and environmental elements to achieve maximum realism." %>
</div>
