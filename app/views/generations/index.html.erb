<div class="max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900">Your Generations</h1>
  </div>

  <% if @generations.any? %>
    <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
      <% @generations.each do |generation| %>
        <%= link_to generation_path(generation), class: "block transform transition-all duration-500 ease-in-out hover:animate-float" do %>
          <div class="polaroid-wrapper group">
            <div class="bg-polaroid-frame p-5 pb-20 rounded shadow-polaroid hover:shadow-polaroid-hover transform transition-all duration-500 ease-in-out hover:animate-wiggle relative overflow-hidden border border-polaroid-border">
              <% if generation.image_url.present? %>
                <div class="aspect-[2/3] w-full overflow-hidden">
                  <%= image_tag generation.image_url, class: "w-full h-full object-cover object-center group-hover:opacity-90" %>
                </div>
              <% else %>
                <div class="aspect-[2/3] w-full bg-gray-100 flex items-center justify-center">
                  <p class="text-gray-500">Processing...</p>
                </div>
              <% end %>
              
              <div class="absolute inset-0 pointer-events-none opacity-[0.085] mix-blend-multiply" style="background-image: url('data:image/svg+xml,%3Csvg width=\'100\' height=\'100\' viewBox=\'0 0 100 100\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cfilter id=\'noise\'%3E%3CfeTurbulence type=\'fractalNoise\' baseFrequency=\'0.8\' numOctaves=\'4\' stitchTiles=\'stitch\'/%3E%3C/filter%3E%3Crect width=\'100\' height=\'100\' filter=\'url(%23noise)\' opacity=\'0.5\'/%3E%3C/svg%3E')"></div>
              
              <div class="mt-4 text-center relative">
                <p class="font-handwriting text-sm text-gray-900 truncate px-2"><%= generation.prompt %></p>
                <div class="mt-3 flex justify-center items-center space-x-2">
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                    <%= generation.style.titleize %>
                  </span>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                    <%= generation.size %>
                  </span>
                </div>
                <div class="mt-3 flex justify-between items-center px-2">
                  <span class="text-xs text-gray-500 font-handwriting">
                    <%= time_ago_in_words(generation.created_at) %> ago
                  </span>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-handwriting <%= generation.status == 'completed' ? 'bg-green-100 text-green-800' : 'bg-yellow-100 text-yellow-800' %>">
                    <%= generation.status.titleize %>
                  </span>
                </div>
                <div class="absolute bottom-0 left-0 right-0 p-2 flex justify-around items-center text-gray-700 font-handwriting text-xs">
                  <div class="flex items-center space-x-1">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                    </svg>
                    <span><%= generation.view_count %></span>
                  </div>
                  <div class="flex items-center space-x-1">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd" />
                    </svg>
                    <span><%= generation.like_count %></span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-12">
      <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
      </svg>
      <h3 class="mt-2 text-sm font-medium text-gray-900">No Images Yet</h3>
      <p class="mt-1 text-sm text-gray-500">Get started by creating your first AI-generated image using the button in the header above.</p>
    </div>
  <% end %>
</div>
