<div class="max-w-2xl mx-auto py-8">
  <h1 class="text-3xl font-bold text-gray-900 mb-8">Create New Image</h1>

  <%= form_with(model: @generation, class: "space-y-6") do |f| %>
    <% if @generation.errors.any? %>
      <div class="bg-red-50 p-4 rounded-md">
        <div class="flex">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
            </svg>
          </div>
          <div class="ml-3">
            <h3 class="text-sm font-medium text-red-800">
              <%= pluralize(@generation.errors.count, "error") %> prevented this generation from being saved:
            </h3>
            <div class="mt-2 text-sm text-red-700">
              <ul class="list-disc pl-5 space-y-1">
                <% @generation.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <div>
      <%= f.label :prompt, class: "block text-sm font-medium text-gray-700" %>
      <div class="mt-1">
        <%= f.text_area :prompt, rows: 4, class: "shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md", placeholder: "Describe the image you want to generate..." %>
      </div>
      <p class="mt-2 text-sm text-gray-500">Be specific and descriptive about what you want to see in the image.</p>
    </div>

    <div>
      <%= f.label :style, class: "block text-sm font-medium text-gray-700" %>
      <div class="mt-1">
        <%= f.select :style, Generation::STYLES.keys.map { |style| [style.to_s.titleize, style] }, {}, class: "shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md" %>
      </div>
    </div>

    <div>
      <%= f.label :size, class: "block text-sm font-medium text-gray-700" %>
      <div class="mt-1">
        <%= f.select :size, Generation::SIZES.map { |key, value| ["#{key.to_s.titleize} (#{value})", value] }, {}, class: "shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md" %>
      </div>
    </div>

    <div class="flex justify-end">
      <%= f.submit "Generate Image", class: "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
    </div>
  <% end %>
</div>
