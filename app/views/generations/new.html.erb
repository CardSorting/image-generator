            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
             <h2 class="absolute top-4 left-4 text-3xl font-handwriting text-white" style="text-shadow: 2px 2px 4px #000;">Cartoon</h2>
          </div>

          <div class="mt-4 text-center relative pb-20">
            <p class="font-handwriting text-sm text-gray-900 truncate px-2 -rotate-1"><%= "Cartoon Style" %></p>
            <p class="text-gray-600 text-xs mt-2 px-2 truncate -rotate-1">Fun, animated-style images with bold lines and vibrant colors.</p>
            <div class="mt-3 flex justify-center items-center space-x-2">
              <%= link_to new_style_generations_path(:cartoon), class: "inline-flex items-center px-4 py-2 rounded-md text-sm font-medium bg-blue-600 text-white hover:bg-blue-700" do %>
                Choose Cartoon
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Realistic Style Card -->
    <div class="transform transition-all duration-500 ease-in-out hover:animate-float">
      <div class="polaroid-wrapper group odd:rotate-1 even:-rotate-1">
        <div class="bg-polaroid-frame p-5 pb-20 rounded shadow-polaroid hover:shadow-polaroid-hover transform transition-all duration-500 ease-in-out hover:animate-wiggle relative overflow-hidden border border-polaroid-border">
          <div class="aspect-[2/3] w-full overflow-hidden bg-gray-100 relative">
