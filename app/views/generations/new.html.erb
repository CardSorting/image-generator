<div class="max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
  <h1 class="text-3xl font-bold text-gray-900 mb-8">Choose Your Generation Style</h1>
  
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-6">
    <!-- Natural Style Card -->
    <div class="bg-white rounded-lg shadow-sm hover:shadow-lg transition-shadow duration-200">
      <div class="p-6">
        <h2 class="text-2xl font-semibold text-gray-900 mb-3">Natural</h2>
        <p class="text-gray-600 mb-4">
          Create photorealistic images with natural lighting and textures. Perfect for landscapes, 
          portraits, and real-world scenes.
        </p>
        <div class="mt-4">
          <%= link_to new_style_generations_path(:natural), class: "inline-flex items-center justify-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 w-full" do %>
            Choose Natural Style
          <% end %>
        </div>
      </div>
    </div>

    <!-- Artistic Style Card -->
    <div class="bg-white rounded-lg shadow-sm hover:shadow-lg transition-shadow duration-200">
      <div class="p-6">
        <h2 class="text-2xl font-semibold text-gray-900 mb-3">Artistic</h2>
        <p class="text-gray-600 mb-4">
          Create unique artistic interpretations with creative flair. Perfect for abstract concepts 
          and stylized scenes.
        </p>
        <div class="mt-4">
          <%= link_to new_style_generations_path(:artistic), class: "inline-flex items-center justify-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 w-full" do %>
            Choose Artistic Style
          <% end %>
        </div>
      </div>
    </div>

    <!-- Cartoon Style Card -->
    <div class="bg-white rounded-lg shadow-sm hover:shadow-lg transition-shadow duration-200">
      <div class="p-6">
        <h2 class="text-2xl font-semibold text-gray-900 mb-3">Cartoon</h2>
        <p class="text-gray-600 mb-4">
          Create fun, animated-style images with bold lines and vibrant colors. Perfect for 
          character designs and playful scenes.
        </p>
        <div class="mt-4">
          <%= link_to new_style_generations_path(:cartoon), class: "inline-flex items-center justify-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 w-full" do %>
            Choose Cartoon Style
          <% end %>
        </div>
      </div>
    </div>

    <!-- Realistic Style Card -->
    <div class="bg-white rounded-lg shadow-sm hover:shadow-lg transition-shadow duration-200">
      <div class="p-6">
        <h2 class="text-2xl font-semibold text-gray-900 mb-3">Realistic</h2>
        <p class="text-gray-600 mb-4">
          Create highly detailed, photorealistic images with precise textures and lighting. Perfect for 
          professional results.
        </p>
        <div class="mt-4">
          <%= link_to new_style_generations_path(:realistic), class: "inline-flex items-center justify-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 w-full" do %>
            Choose Realistic Style
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
