            <% else %>
              <%= style_placeholder('realistic') %>
            <% end %>
            <div class="absolute inset-0 pointer-events-none opacity-[0.085] mix-blend-multiply" style="background-image: url('data:image/svg+xml,%3Csvg width=\'100\' height=\'100\' viewBox=\'0 0 100 100\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cfilter id=\'noise\'%3E%3CfeTurbulence type=\'fractalNoise\' baseFrequency=\'0.8\' numOctaves=\'4\' stitchTiles=\'stitch\'/%3E%3C/filter%3E%3Crect width=\'100\' height=\'100\' filter=\'url(%23noise)\' opacity=\'0.5\'/%3E%3C/svg%3E')"></div>
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
             <h2 class="absolute top-4 left-4 text-3xl font-handwriting text-white" style="text-shadow: 2px 2px 4px #000;">Realistic</h2>
          </div>

          <div class="mt-4 text-center relative pb-20">
            <p class="font-handwriting text-sm text-gray-900 truncate px-2 -rotate-1"><%= "Realistic Style" %></p>
            <p class="text-gray-600 text-xs mt-2 px-2 truncate -rotate-1">Highly detailed, photorealistic images with precise textures and lighting.</p>
            <div class="mt-3 flex justify-center items-center space-x-2">
              <%= link_to new_style_generations_path(:realistic), class: "inline-flex items-center px-4 py-2 rounded-md text-sm font-medium bg-blue-600 text-white hover:bg-blue-700" do %>
