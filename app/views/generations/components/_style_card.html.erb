<%# Local variables: presenter (StylePresenter instance) %>

<div class="<%= presenter.card_classes %>" data-controller="style-card">
  <%# Card Header with Image %>
  <%= link_to style_path(presenter.style_name), class: "block relative" do %>
    <div class="<%= presenter.image_container_classes %>">
      <% if (image_url = sample_image_for_style(presenter.style_name)) %>
        <%= image_tag image_url, class: presenter.image_classes %>
      <% else %>
        <div class="<%= presenter.placeholder_classes %>">
          <span class="text-4xl font-handwriting text-gray-500">
            <%= presenter.title %>
          </span>
        </div>
      <% end %>
      
      <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
      
      <%# Title and Trending Badge %>
      <div class="absolute inset-x-0 top-0 p-4 flex justify-between items-start">
        <h2 class="text-2xl font-handwriting text-white drop-shadow-lg">
          <%= presenter.title %>
        </h2>
        <% if presenter.is_trending? %>
          <div class="<%= presenter.metric_badge_classes(:trending) %> animate-pulse">
            <svg class="w-3 h-3 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
            </svg>
            <span>Trending</span>
          </div>
        <% end %>
      </div>

      <%# Quick Stats Overlay %>
      <div class="absolute inset-x-0 bottom-0 p-4 flex justify-between items-end">
        <div class="flex items-center space-x-4 text-white text-sm">
          <div class="flex items-center">
            <svg class="w-4 h-4 mr-1 opacity-75" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
            </svg>
            <%= presenter.format_number(presenter.views_count) %>
          </div>
          <div class="flex items-center">
            <svg class="w-4 h-4 mr-1 opacity-75" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
            </svg>
            <%= presenter.format_number(presenter.likes_count) %>
          </div>
        </div>
        <div class="<%= presenter.metric_badge_classes(:engagement) %>">
          <%= presenter.engagement_rate %>%
        </div>
      </div>
    </div>
  <% end %>

  <%# Card Content %>
  <div class="p-4">
    <p class="text-sm text-gray-600 mb-4">
      <%= truncate(presenter.description, length: 100) %>
    </p>
    
    <%# Action Buttons %>
    <div class="flex gap-2">
      <%= link_to new_style_generations_path(presenter.style_name), 
          class: "flex-1 inline-flex items-center justify-center px-4 py-2 rounded-md text-sm font-medium bg-blue-600 text-white hover:bg-blue-700 transition-colors" do %>
        <svg class="w-4 h-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
        </svg>
        Try Now
      <% end %>

      <%= link_to gallery_style_path(presenter.style_name),
          class: "inline-flex items-center justify-center px-3 py-2 rounded-md text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 transition-colors" do %>
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
      <% end %>

      <%= link_to analytics_style_path(presenter.style_name),
          class: "inline-flex items-center justify-center px-3 py-2 rounded-md text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 transition-colors" do %>
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
        </svg>
      <% end %>
    </div>
  </div>
</div>
