<%# Local variables: category (Symbol), styles (Array of style names) %>

<% metadata = StyleRegistry.categories[category] %>

<section class="mb-12 last:mb-0">
  <div class="<%= metadata[:theme] %> rounded-lg p-6 mb-6">
    <h2 class="text-2xl font-bold text-gray-900 mb-2">
      <%= metadata[:title] %>
    </h2>
    <p class="text-gray-600">
      <%= metadata[:description] %>
    </p>
  </div>

  <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
    <% metadata[:styles].each do |style_name| %>
      <%= render "generations/components/style_card",
                 presenter: StylePresenter.new(style_name) %>
    <% end %>
  </div>
</section>
