<div class="flex flex-col items-center justify-center py-12">
  <h1 class="text-4xl font-bold text-gray-900 mb-8">AI Image Generator</h1>
  
  <div class="text-center max-w-2xl mb-8">
    <p class="text-lg text-gray-600 mb-4">
      Transform your ideas into stunning images using artificial intelligence.
      Create unique artworks, illustrations, and designs with just a text description.
    </p>
    
    <div class="space-y-4">
      <% if user_signed_in? %>
        <%= link_to new_generation_path, class: "inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700" do %>
          Create New Image
        <% end %>
        
        <%= link_to generations_path, class: "block text-indigo-600 hover:text-indigo-500" do %>
          View Your Generations
        <% end %>
      <% else %>
        <%= link_to new_user_session_path, class: "inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700" do %>
          Sign in to Get Started
        <% end %>
        
        <%= link_to new_user_registration_path, class: "block mt-2 text-indigo-600 hover:text-indigo-500" do %>
          Create an Account
        <% end %>
      <% end %>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl">
    <div class="p-6 bg-white rounded-lg shadow-sm">
      <h3 class="text-lg font-medium text-gray-900 mb-2">Multiple Styles</h3>
      <p class="text-gray-600">Choose from various artistic styles including natural, artistic, cartoon, and realistic.</p>
    </div>
    
    <div class="p-6 bg-white rounded-lg shadow-sm">
      <h3 class="text-lg font-medium text-gray-900 mb-2">Custom Sizes</h3>
      <p class="text-gray-600">Generate images in different sizes to suit your needs, from small thumbnails to large artwork.</p>
    </div>
    
    <div class="p-6 bg-white rounded-lg shadow-sm">
      <h3 class="text-lg font-medium text-gray-900 mb-2">Easy Download</h3>
      <p class="text-gray-600">Download your generated images instantly and use them in your projects.</p>
    </div>
  </div>
</div>
