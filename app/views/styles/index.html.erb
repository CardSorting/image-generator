<div class="min-h-screen bg-gray-50 flex">
  <%# Sidebar %>
  <%= render 'sidebar' %>

  <%# Main Content %>
  <div class="flex-1 ml-64">  <%# ml-64 matches sidebar width %>
    <div class="py-8 px-6">
      <%# Trending Styles Section %>
      <% if @trending_styles.any? && params[:category].nil? %>
        <section class="mb-12">
          <h2 class="text-2xl font-bold text-gray-900 mb-6">Trending Styles</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <% @trending_styles.each do |presenter| %>
              <div class="relative group rounded-lg overflow-hidden bg-gradient-to-br <%= presenter.theme_classes %> shadow-lg">
                <%= link_to style_path(presenter.style_name), class: "block" do %>
                  <div class="p-6">
                    <div class="flex items-center justify-between mb-4">
                      <h3 class="text-xl font-medium text-white"><%= presenter.title %></h3>
                      <div class="<%= presenter.metric_badge_classes(:trending) %> animate-pulse">
                        <svg class="w-3 h-3 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
                        </svg>
                        Trending
                      </div>
                    </div>

                    <p class="text-white/80 text-sm mb-4"><%= presenter.description %></p>

                    <div class="flex items-center justify-between text-white/90">
                      <div class="flex items-center space-x-4">
                        <div class="flex items-center">
                          <svg class="w-4 h-4 mr-1 opacity-75" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                          </svg>
                          <%= presenter.format_number(presenter.views_count) %>
                        </div>
                        <div class="flex items-center">
                          <svg class="w-4 h-4 mr-1 opacity-75" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                          </svg>
                          <%= presenter.format_number(presenter.likes_count) %>
                        </div>
                      </div>
                      <span class="<%= presenter.metric_badge_classes(:engagement) %>">
                        <%= presenter.engagement_rate %>% Engagement
                      </span>
                    </div>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        </section>
      <% end %>

      <%# Category Styles Grid %>
      <section>
        <% if params[:category] %>
          <% category = StyleRegistry.categories[params[:category].to_sym] %>
          <h2 class="text-2xl font-bold text-gray-900 mb-2"><%= category[:title] %></h2>
          <p class="text-gray-600 mb-6"><%= category[:description] %></p>
        <% elsif !@trending_styles.any? %>
          <h2 class="text-2xl font-bold text-gray-900 mb-6">All Styles</h2>
        <% end %>

        <div data-controller="infinite-scroll"
             data-infinite-scroll-url-value="<%= styles_path %>"
             data-infinite-scroll-page-value="1"
             data-infinite-scroll-loading-value="false">
          
          <div id="styles-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
            <% display_styles = params[:category] ? @paginated_styles.select { |s| s.category.to_s == params[:category] } : @paginated_styles %>
            <% display_styles.each do |presenter| %>
              <%= render "style_card", presenter: presenter %>
            <% end %>
          </div>

          <%# Pagination target for infinite scroll %>
          <div data-infinite-scroll-target="pagination" class="h-4"></div>
        </div>
      </section>
    </div>
  </div>
</div>
