<div class="min-h-screen bg-gray-50 flex">
  <%# Sidebar %>
  <%= render 'sidebar' %>

  <%# Main Content %>
  <div class="flex-1 ml-64">  <%# ml-64 matches sidebar width %>
    <div class="py-8 px-6">
      <%# Trending Styles Section %>
      <% if @trending_styles.any? && params[:category].nil? %>
        <section class="mb-12">
          <h2 class="text-2xl font-bold text-gray-900 mb-6">Trending Styles</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <% @trending_styles.each do |presenter| %>
              <div class="relative group rounded-lg overflow-hidden bg-gradient-to-br <%= presenter.theme_classes %> shadow-lg">
                <%= link_to style_path(presenter.style_name), class: "block" do %>
                  <div class="p-6">
                    <div class="flex items-center justify-between mb-4">
                      <h3 class="text-xl font-medium text-white"><%= presenter.title %></h3>
                      <div class="<%= presenter.metric_badge_classes(:trending) %> animate-pulse">
                        <svg class="w-3 h-3 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
                        </svg>
                        Trending
                      </div>
                    </div>

                    <p class="text-white/80 text-sm mb-4"><%= presenter.description %></p>

                    <div class="flex items-center justify-between text-white/90">
                      <div class="flex items-center space-x-4">
                        <div class="flex items-center">
                          <svg class="w-4 h-4 mr-1 opacity-75" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                          </svg>
                          <%= presenter.format_number(presenter.views_count) %>
                        </div>
                        <div class="flex items-center">
                          <svg class="w-4 h-4 mr-1 opacity-75" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                          </svg>
                          <%= presenter.format_number(presenter.likes_count) %>
                        </div>
                      </div>
                      <span class="<%= presenter.metric_badge_classes(:engagement) %>">
                        <%= presenter.engagement_rate %>% Engagement
                      </span>
                    </div>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        </section>
      <% end %>

      <%# Category Styles Grid %>
      <section>
        <% if params[:category] %>
          <% category = StyleRegistry.categories[params[:category].to_sym] %>
          <h2 class="text-2xl font-bold text-gray-900 mb-2"><%= category[:title] %></h2>
          <p class="text-gray-600 mb-6"><%= category[:description] %></p>
        <% elsif !@trending_styles.any? %>
          <h2 class="text-2xl font-bold text-gray-900 mb-6">All Styles</h2>
        <% end %>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
          <% display_styles = params[:category] ? @styles.select { |s| s.category.to_s == params[:category] } : @styles %>
          <% display_styles.each do |presenter| %>
            <div class="<%= presenter.card_classes %>" data-controller="style-card">
              <%# Card Header with Image %>
              <%= link_to style_path(presenter.style_name), class: "block" do %>
                <div class="<%= presenter.image_container_classes %>">
                  <% if (image_url = sample_image_for_style(presenter.style_name)) %>
                    <%= image_tag image_url, class: presenter.image_classes %>
                  <% else %>
                    <div class="<%= presenter.placeholder_classes %>">
                      <span class="text-4xl font-handwriting text-gray-500">
                        <%= presenter.title %>
                      </span>
                    </div>
                  <% end %>
                  
                  <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
                  
                  <div class="absolute inset-x-0 bottom-0 p-4">
                    <h3 class="text-xl font-medium text-white mb-2"><%= presenter.title %></h3>
                    <div class="flex items-center justify-between text-white/90 text-sm">
                      <div class="flex items-center space-x-3">
                        <span><%= presenter.total_generations %> generations</span>
                        <span><%= presenter.engagement_rate %>% engagement</span>
                      </div>
                      <% if presenter.is_trending? %>
                        <div class="<%= presenter.metric_badge_classes(:trending) %> animate-pulse">
                          <svg class="w-3 h-3 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
                          </svg>
                          Trending
                        </div>
                      <% end %>
                    </div>
                  </div>
                </div>
              <% end %>

              <%# Action Button %>
              <div class="p-4 bg-white">
                <div class="flex gap-2">
                  <%= link_to new_style_generations_path(presenter.style_name), 
                      class: "flex-1 inline-flex items-center justify-center px-4 py-2 rounded-md text-sm font-medium bg-blue-600 text-white hover:bg-blue-700 transition-colors" do %>
                    <svg class="w-4 h-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
                    </svg>
                    Try Now
                  <% end %>

                  <%= link_to gallery_style_path(presenter.style_name),
                      class: "inline-flex items-center justify-center px-3 py-2 rounded-md text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 transition-colors" do %>
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </section>
    </div>
  </div>
</div>
