<div class="min-h-screen bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-green-50 via-gray-50 to-white" data-controller="style-page">
  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
    <div class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg width=\"20\" height=\"20\" viewBox=\"0 0 20 20\" xmlns=\"http://www.w3.org/2000/svg\"%3E%3Cg fill=\"%2322c55e\" fill-opacity=\"0.03\" fill-rule=\"evenodd\"%3E%3Ccircle cx=\"3\" cy=\"3\" r=\"3\"/%3E%3C/g%3E%3C/svg%3E')] opacity-40"></div>
    <!-- Header -->
    <div class="text-center mb-20">
      <div class="flex items-center justify-center space-x-4 mb-8">
        <div class="bg-green-100 text-green-800 px-5 py-2.5 rounded-full text-sm font-semibold shadow-sm ring-1 ring-green-200 hover:bg-green-200 hover:text-green-900 transition-colors duration-200">
          Photography Style
        </div>
        <div class="bg-white text-gray-700 px-5 py-2.5 rounded-full text-sm font-semibold shadow-sm flex items-center border border-gray-200 hover:border-gray-300 transition-colors">
              <div class="flex items-center mr-2">
                <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
                <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
                <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
                <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
                <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              </div>
              4.9 Rating
            </div>
        </div>
      </div>
      
      <h1 class="text-6xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-gray-900 via-green-900 to-gray-900 mb-8 tracking-tight">Natural Style Generation</h1>
      
      <p class="text-xl text-gray-600 leading-relaxed max-w-2xl mx-auto font-medium">
        Create photorealistic images with natural lighting and textures. Perfect for landscapes, 
        portraits, and real-world scenes that look like they were captured by a camera.
      </p>
    </div>

    <!-- Main Content -->
    <div class="space-y-12">
      <!-- Generation Form -->
      <div class="relative bg-white/90 rounded-2xl shadow-xl p-10 transform hover:shadow-2xl transition duration-300 border border-gray-200 backdrop-blur-lg group" data-style-page-target="form">
        <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-green-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <div class="relative flex items-center justify-between mb-8 border-b border-gray-100 pb-6">
          <h2 class="text-3xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-gray-900 to-green-800 tracking-tight">Create Your Image</h2>
          <div class="flex items-center space-x-3 bg-green-50 px-4 py-2 rounded-full border border-green-100/50 shadow-sm">
            <div class="relative">
              <div class="w-2.5 h-2.5 rounded-full bg-green-500 animate-pulse"></div>
              <div class="absolute inset-0 w-2.5 h-2.5 rounded-full bg-green-400 animate-ping opacity-75"></div>
            </div>
            <span class="text-sm font-medium bg-gradient-to-r from-green-800 to-green-600 bg-clip-text text-transparent">AI Ready</span>
          </div>
        </div>
        <% if user_signed_in? %>
          <%= render "form", 
            prompt_placeholder: "Example: A serene mountain lake at sunrise, with morning mist rising from the water...", 
            prompt_help: "Focus on natural elements, lighting conditions, and realistic details you'd see in a photograph." %>
        <% else %>
          <div class="relative text-center py-16">
            <h3 class="text-2xl font-semibold text-transparent bg-clip-text bg-gradient-to-r from-gray-900 to-green-800 mb-4">Sign in to Generate Images</h3>
            <p class="text-gray-600 mb-8 max-w-md mx-auto">Create an account or sign in to start generating natural style images.</p>
            <div class="relative inline-block">
              <%= link_to new_user_session_path, class: "group relative inline-flex justify-center py-3 px-8 shadow-lg text-sm font-medium rounded-xl text-white overflow-hidden focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" do %>
                <div class="absolute inset-0 w-full h-full transition-all duration-300 bg-gradient-to-r from-green-600 via-green-500 to-green-600 group-hover:scale-102"></div>
                <div class="absolute inset-0 w-full h-full transition-all duration-300 opacity-0 group-hover:opacity-20 bg-[radial-gradient(circle_at_center,_white_0%,_transparent_100%)]"></div>
                <span class="relative">Sign in</span>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

      <!-- Community Link -->
      <div class="relative bg-gradient-to-br from-green-50 to-white rounded-xl shadow-lg p-10 border border-green-100 overflow-hidden group">
        <div class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg width=\"20\" height=\"20\" viewBox=\"0 0 20 20\" xmlns=\"http://www.w3.org/2000/svg\"%3E%3Cg fill=\"%2322c55e\" fill-opacity=\"0.05\" fill-rule=\"evenodd\"%3E%3Ccircle cx=\"3\" cy=\"3\" r=\"3\"/%3E%3C/g%3E%3C/svg%3E')] opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <div class="relative text-center">
          <h3 class="text-2xl font-semibold text-transparent bg-clip-text bg-gradient-to-r from-gray-900 to-green-800 mb-4">View Community Generations</h3>
          <p class="text-gray-600 mb-10">Explore what others have created with this style</p>
          <div class="relative inline-block w-full">
            <%= link_to gallery_style_path("natural"), class: "group relative inline-flex items-center justify-center w-full px-8 py-4 text-base font-medium text-white overflow-hidden rounded-xl shadow-lg focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" do %>
              <div class="absolute inset-0 w-full h-full transition-all duration-300 bg-gradient-to-r from-green-600 via-green-500 to-green-600 group-hover:scale-102"></div>
              <div class="absolute inset-0 w-full h-full transition-all duration-300 opacity-0 group-hover:opacity-20 bg-[radial-gradient(circle_at_center,_white_0%,_transparent_100%)]"></div>
              <span class="relative">Browse Gallery</span>
              <svg class="relative w-5 h-5 ml-2 transform group-hover:translate-x-1 transition-transform duration-150" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
