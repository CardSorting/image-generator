<div class="min-h-screen bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-green-50 via-gray-50 to-white" data-controller="style-page">
  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
    <!-- Header -->
    <div class="text-center mb-20">
      <h1 class="text-6xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-gray-900 via-green-900 to-gray-900 mb-8 tracking-tight">Natural Style Generation</h1>
      <p class="text-xl text-gray-600 leading-relaxed max-w-2xl mx-auto font-medium">
        Create photorealistic images with natural lighting and textures.
      </p>
    </div>

    <!-- Generation Form -->
    <div class="relative bg-white/90 rounded-2xl shadow-xl p-10 transform hover:shadow-2xl transition duration-300 border border-gray-200 backdrop-blur-lg group" data-style-page-target="form">
      <div class="relative flex items-center justify-between mb-8 border-b border-gray-100 pb-6">
        <h2 class="text-3xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-gray-900 to-green-800 tracking-tight">Create Your Image</h2>
      </div>
      <% if user_signed_in? %>
        <%= render "generations/form", 
          prompt_placeholder: "Example: A serene mountain lake at sunrise, with morning mist rising from the water...", 
          prompt_help: "Focus on natural elements, lighting conditions, and realistic details you'd see in a photograph." %>
      <% else %>
        <div class="relative text-center py-16">
          <h3 class="text-2xl font-semibold text-transparent bg-clip-text bg-gradient-to-r from-gray-900 to-green-800 mb-4">Sign in to Generate Images</h3>
          <p class="text-gray-600 mb-8 max-w-md mx-auto">Create an account or sign in to start generating natural style images.</p>
          <div class="relative inline-block">
            <%= link_to new_user_session_path, class: "group relative inline-flex justify-center py-3 px-8 shadow-lg text-sm font-medium rounded-xl text-white overflow-hidden focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" do %>
              <div class="absolute inset-0 w-full h-full transition-all duration-300 bg-gradient-to-r from-green-600 via-green-500 to-green-600 group-hover:scale-102"></div>
              <div class="absolute inset-0 w-full h-full transition-all duration-300 opacity-0 group-hover:opacity-20 bg-[radial-gradient(circle_at_center,_white_0%,_transparent_100%)]"></div>
              <span class="relative">Sign in</span>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
