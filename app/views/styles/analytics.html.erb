<div class="min-h-screen bg-gray-50">
  <%# Navigation Bar %>
  <div class="bg-white border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <div class="flex items-center">
          <%= link_to style_path(@style), class: "flex items-center text-gray-500 hover:text-gray-700" do %>
            <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
            </svg>
            Back to Style Details
          <% end %>
        </div>
        <h1 class="text-xl font-semibold text-gray-900">
          <%= @presenter.title %> Analytics
        </h1>
        <div class="flex items-center">
          <%= button_to try_style_path(@style), class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700" do %>
            <svg class="w-4 h-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
            </svg>
            Try Style
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <%# Overview Stats %>
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4 mb-8">
      <div class="bg-white overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 truncate">Total Views</dt>
                <dd class="flex items-baseline">
                  <div class="text-2xl font-semibold text-gray-900">
                    <%= number_with_delimiter(@presenter.views_count) %>
                  </div>
                </dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 truncate">Total Likes</dt>
                <dd class="flex items-baseline">
                  <div class="text-2xl font-semibold text-gray-900">
                    <%= number_with_delimiter(@presenter.likes_count) %>
                  </div>
                </dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 truncate">Total Saves</dt>
                <dd class="flex items-baseline">
                  <div class="text-2xl font-semibold text-gray-900">
                    <%= number_with_delimiter(@presenter.bookmarks_count) %>
                  </div>
                </dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 truncate">Engagement Rate</dt>
                <dd class="flex items-baseline">
                  <div class="text-2xl font-semibold <%= @presenter.engagement_color_class %>">
                    <%= number_to_percentage(@presenter.engagement_rate, precision: 1) %>
                  </div>
                </dd>
              </dl>
            </div>
          </div>
        </div>
      </div>
    </div>

    <%# Weekly Trend %>
    <div class="bg-white shadow rounded-lg p-6 mb-8">
      <h3 class="text-lg font-medium text-gray-900 mb-4">Weekly Generation Trend</h3>
      <div class="relative h-[300px]">
        <%# This is a placeholder for a chart - you'll need to integrate a charting library %>
        <div class="absolute inset-0 flex items-center justify-center text-gray-400">
          <% @weekly_trend.each do |date, count| %>
            <div class="relative flex-1 h-full" style="min-width: 40px">
              <div class="absolute bottom-0 inset-x-0 mx-1">
                <div class="bg-blue-500 rounded-t"
                     style="height: <%= (count.to_f / @weekly_trend.values.max * 100).round %>%">
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
      <%# Popular Tags %>
      <div class="bg-white shadow rounded-lg p-6">
        <h3 class="text-lg font-medium text-gray-900 mb-4">Popular Tags</h3>
        <div class="space-y-4">
          <% @presenter.popular_tags.each do |tag| %>
            <div class="flex items-center">
              <span class="flex-1 text-sm text-gray-600">#<%= tag %></span>
              <div class="ml-4">
                <span class="px-2.5 py-0.5 text-xs font-medium bg-blue-100 text-blue-800 rounded-full">
                  Popular
                </span>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <%# Generation Times %>
      <div class="bg-white shadow rounded-lg p-6">
        <h3 class="text-lg font-medium text-gray-900 mb-4">Generation Performance</h3>
        <dl class="space-y-4">
          <div>
            <dt class="text-sm font-medium text-gray-500">Average Generation Time</dt>
            <dd class="mt-1 flex justify-between items-baseline">
              <div class="text-2xl font-semibold text-gray-900">
                <%= number_with_precision(@stats[:avg_generation_time], precision: 1) %>s
              </div>
              <div class="text-sm text-gray-500">
                Last 7 days
              </div>
            </dd>
          </div>

          <div>
            <dt class="text-sm font-medium text-gray-500">Success Rate</dt>
            <dd class="mt-1">
              <div class="flex items-center">
                <div class="flex-1">
                  <div class="h-2 bg-gray-200 rounded-full">
                    <div class="h-2 bg-green-500 rounded-full" 
                         style="width: <%= @stats[:success_rate] %>%"></div>
                  </div>
                </div>
                <span class="ml-3 text-sm font-medium text-gray-900">
                  <%= number_to_percentage(@stats[:success_rate], precision: 1) %>
                </span>
              </div>
            </dd>
          </div>
        </dl>
      </div>
    </div>
  </div>
</div>
