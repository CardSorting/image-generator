<div class="w-64 bg-white shadow-sm border-r border-gray-200 h-screen fixed left-0 overflow-y-auto">
  <div class="p-4">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">Categories</h2>
    <nav>
      <ul class="space-y-1">
        <%# Trending Section %>
        <%= link_to styles_path(category: nil), class: "block px-4 py-2 rounded-md #{params[:category].nil? ? 'bg-blue-50 text-blue-700' : 'text-gray-700 hover:bg-gray-50'}" do %>
          <div class="flex items-center">
            <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
            </svg>
            Trending
          </div>
        <% end %>

        <%# Category Links %>
        <% StyleRegistry.categories.each do |category_id, category| %>
          <%= link_to styles_path(category: category_id), class: "block px-4 py-2 rounded-md #{params[:category].to_s == category_id.to_s ? 'bg-blue-50 text-blue-700' : 'text-gray-700 hover:bg-gray-50'}" do %>
            <div class="flex items-center justify-between">
              <span><%= category[:title] %></span>
              <span class="bg-gray-100 text-gray-600 text-xs px-2 py-1 rounded-full">
                <%= @styles.select { |s| s.category == category_id }.count %>
              </span>
            </div>
          <% end %>
        <% end %>
      </ul>
    </nav>
  </div>
</div>
